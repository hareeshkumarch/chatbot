OTEL_EXPORTER_ENDPOINT=
OTEL_SERVICE_NAME=enterprise-ai-platform
OTEL_ENABLED=false

PHOENIX_ENABLED=true
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_PROJECT_NAME=enterprise-ai-platform
PHOENIX_UI_URL=http://localhost:6006

SMALL_CORPUS_THRESHOLD=1000
LARGE_CORPUS_THRESHOLD=100000

MAX_UPLOAD_MB=100
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.96
SEMANTIC_CACHE_TTL_SECONDS=3600

SQL_AGENT_ROW_LIMIT=500
